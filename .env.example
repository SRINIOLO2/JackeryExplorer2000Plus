# Jackery Credentials
JACKERY_USERNAME=your_username@email.com
JACKERY_PASSWORD=your_password
# Optional: specific device ID to monitor. If empty, the script auto-discovers and monitors all devices.
JACKERY_DEVICE_ID=your_device_id

# MQTT Broker Configuration (Home Assistant MQTT integration)
MQTT_BROKER=your_mqtt_broker_ip
MQTT_PORT=1883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
# The prefix topic used for Home Assistant auto-discovery. Default is "homeassistant".
MQTT_DISCOVERY_PREFIX=homeassistant

# Telegram Bot Notifications
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Thresholds & Tuning
POLL_INTERVAL_SEC=60
LOW_BATTERY_THRESHOLD=20
CRITICAL_BATTERY_THRESHOLD=5
